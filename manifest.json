{
  "manifest_version": 3,
  "name": "Prompt Chain Extension",
  "version": "0.1.0",
  "description": "Record action recipes on any AI chat site and replay prompt chains automatically.",

  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/constants.js",
        "lib/utils.js",
        "lib/messages.js",
        "lib/storage.js",
        "lib/logger.js",
        "content/selectorEngine.js",
        "content/recorder.js",
        "content/main.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ]
}